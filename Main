-- =====================
-- LOGIC
-- =====================
_G.clicking = false
local minimized = false
local clicks = 0

task.spawn(function()
    while true do
        if _G.clicking then
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Clicker"):FireServer()
            clicks = clicks + 1
            CounterLabel.Text = "Total clicks: " .. clicks
            task.wait(0.03) -- ~33 clicks/sec
        else
            task.wait(0.1)
        end
    end
end)

ToggleButton.MouseButton1Click:Connect(function()
    _G.clicking = not _G.clicking
    if _G.clicking then
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        ToggleButton.Text = "Clicker: ON"
        StatusLabel.Text = "Status: Running"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 200, 100)
    else
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        ToggleButton.Text = "Clicker: OFF"
        StatusLabel.Text = "Status: Idle"
        StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    end
end)

Tab1Btn.MouseButton1Click:Connect(function()
    Tab1Content.Visible = true
    Tab2Content.Visible = false
    Tab1Btn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
    Tab1Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Tab2Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    Tab2Btn.TextColor3 = Color3.fromRGB(180, 180, 180)
end)

Tab2Btn.MouseButton1Click:Connect(function()
    Tab1Content.Visible = false
    Tab2Content.Visible = true
    Tab2Btn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
    Tab2Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Tab1Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    Tab1Btn.TextColor3 = Color3.fromRGB(180, 180, 180)
end)

MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        ContentFrame.Visible = false
        MainFrame.Size = UDim2.new(0, 300, 0, 45)
        MinBtn.Text = "+"
    else
        ContentFrame.Visible = true
        MainFrame.Size = UDim2.new(0, 300, 0, 280)
        MinBtn.Text = "-"
    end
end)

CloseBtn.MouseButton1Click:Connect(function()
    _G.clicking = false
    ScreenGui:Destroy()
end)
