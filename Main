-- ========================
-- RESIZE HANDLE
-- ========================
local ResizeHandle = Instance.new("TextButton")
ResizeHandle.Parent = MainFrame
ResizeHandle.Size = UDim2.new(0, 18, 0, 18)
ResizeHandle.Position = UDim2.new(1, -18, 1, -18)
ResizeHandle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
ResizeHandle.Text = "⊿"
ResizeHandle.TextColor3 = Color3.fromRGB(150, 150, 150)
ResizeHandle.Font = Enum.Font.Gotham
ResizeHandle.TextSize = 11
ResizeHandle.BorderSizePixel = 0
ResizeHandle.ZIndex = 5
local RHCorner = Instance.new("UICorner", ResizeHandle)
RHCorner.CornerRadius = UDim.new(0, 4)

-- Resize logic
local resizing = false
local minW, minH = 240, 240

ResizeHandle.MouseButton1Down:Connect(function()
    resizing = true
    local startMouse = game:GetService("UserInputService"):GetMouseLocation()
    local startSize = MainFrame.AbsoluteSize

    local conn
    conn = game:GetService("RunService").RenderStepped:Connect(function()
        if not resizing then conn:Disconnect() return end
        local mouse = game:GetService("UserInputService"):GetMouseLocation()
        local dx = mouse.X - startMouse.X
        local dy = mouse.Y - startMouse.Y
        local newW = math.max(minW, startSize.X + dx)
        local newH = math.max(minH, startSize.Y + dy)
        MainFrame.Size = UDim2.new(0, newW, 0, newH)
    end)
end)

ResizeHandle.MouseButton1Up:Connect(function() resizing = false end)
game:GetService("UserInputService").InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = false
    end
end)

-- ========================
-- EGG DROPDOWN LOGIC
-- ========================
local selectedEgg = nil
local dropOpen = false
local eggList = {}

local function loadEggs()
    local eggsFolder = ReplicatedStorage:FindFirstChild("Eggs")
    if not eggsFolder then
        DropBtn.Text = "▼  No Eggs folder found"
        return
    end
    for _, egg in ipairs(eggsFolder:GetChildren()) do
        table.insert(eggList, egg.Name)
    end
    -- also catch eggs added later
    eggsFolder.ChildAdded:Connect(function(egg)
        table.insert(eggList, egg.Name)
    end)
end

local function buildDropList()
    -- clear old buttons
    for _, c in ipairs(ScrollFrame:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end

    for i, eggName in ipairs(eggList) do
        local item = Instance.new("TextButton")
        item.Parent = ScrollFrame
        item.Size = UDim2.new(1, -8, 0, 32)
        item.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
        item.Text = eggName
        item.TextColor3 = Color3.fromRGB(220, 220, 220)
        item.Font = Enum.Font.Gotham
        item.TextSize = 12
        item.BorderSizePixel = 0
        item.LayoutOrder = i
        item.ZIndex = 11
        local ic = Instance.new("UICorner", item)
        ic.CornerRadius = UDim.new(0, 6)
        local ip = Instance.new("UIPadding", item)
        ip.PaddingLeft = UDim.new(0, 10)
        item.TextXAlignment = Enum.TextXAlignment.Left

        item.MouseButton1Click:Connect(function()
            selectedEgg = eggName
            DropBtn.Text = "▼  " .. eggName
            dropOpen = false
            DropList.Visible = false
            DropList.Size = UDim2.new(1, 0, 0, 0)
        end)

        item.MouseEnter:Connect(function()
            item.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        end)
        item.MouseLeave:Connect(function()
            item.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
        end)
    end

    local totalH = math.min(#eggList * 34, 120)
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, #eggList * 34)
    DropList.Size = UDim2.new(1, 0, 0, totalH)
end

loadEggs()

DropBtn.MouseButton1Click:Connect(function()
    dropOpen = not dropOpen
    if dropOpen then
        buildDropList()
        DropList.Visible = true
    else
        DropList.Visible = false
        DropList.Size = UDim2.new(1, 0, 0, 0)
    end
end)

-- ========================
-- COIN BYPASS ATTEMPT
-- ========================
local function bypassCoins()
    pcall(function()
        local stats = Player:FindFirstChild("leaderstats")
        if stats then
            for _, v in ipairs(stats:GetChildren()) do
                if v.Name:lower():find("coin") or v.Name:lower():find("cash") or v.Name:lower():find("gem") then
                    v.Value = v.Value + 999999999
                end
            end
        end
    end)
end

-- ========================
-- LOGIC / STATE
-- ========================
_G.clicking = false
_G.hatching = false
local minimized = false
local clicks = 0
local hatched = 0

-- Auto clicker loop
task.spawn(function()
    while true do
        if _G.clicking then
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Clicker"):FireServer()
            clicks = clicks + 1
            CounterLabel.Text = "Total clicks: " .. clicks
            task.wait(0.03)
        else
            task.wait(0.1)
        end
    end
end)

-- Auto hatch loop
task.spawn(function()
    while true do
        if _G.hatching and selectedEgg then
            bypassCoins()
            pcall(function()
                local args = { selectedEgg, 1 }
                ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Egg"):InvokeServer(unpack(args))
            end)
            hatched = hatched + 1
            HatchCountLabel.Text = "Hatched: " .. hatched
            task.wait(0.1)
        else
            task.wait(0.1)
        end
    end
end)

-- Clicker toggle
ToggleButton.MouseButton1Click:Connect(function()
    _G.clicking = not _G.clicking
    if _G.clicking then
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        ToggleButton.Text = "Clicker: ON"
        StatusLabel.Text = "Status: Running"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 200, 100)
    else
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        ToggleButton.Text = "Clicker: OFF"
        StatusLabel.Text = "Status: Idle"
        StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    end
end)

-- Hatch toggle
HatchToggle.MouseButton1Click:Connect(function()
    if not selectedEgg then
        HatchStatusLabel.Text = "⚠ Pick an egg first!"
        HatchStatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
        return
    end
    _G.hatching = not _G.hatching
    if _G.hatching then
        HatchToggle.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        HatchToggle.Text = "Auto Hatch: ON"
        HatchStatusLabel.Text = "Hatching: " .. selectedEgg
        HatchStatusLabel.TextColor3 = Color3.fromRGB(0, 200, 100)
    else
        HatchToggle.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        HatchToggle.Text = "Auto Hatch: OFF"
        HatchStatusLabel.Text = "Status: Idle"
        HatchStatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    end
end)

-- Tab switching
local function setTab(active, content)
    for _, btn in ipairs({Tab1Btn, Tab2Btn, Tab3Btn}) do
        btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        btn.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
    for _, frame in ipairs({Tab1Content, Tab2Content, Tab3Content}) do
        frame.Visible = false
    end
    active.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
    active.TextColor3 = Color3.fromRGB(255, 255, 255)
    content.Visible = true
end

Tab1Btn.MouseButton1Click:Connect(function() setTab(Tab1Btn, Tab1Content) end)
Tab2Btn.MouseButton1Click:Connect(function() setTab(Tab2Btn, Tab2Content) end)
Tab3Btn.MouseButton1Click:Connect(function() setTab(Tab3Btn, Tab3Content) end)

-- Minimize
MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        ContentFrame.Visible = false
        MainFrame.Size = UDim2.new(0, MainFrame.AbsoluteSize.X, 0, 45)
        MinBtn.Text = "+"
    else
        ContentFrame.Visible = true
        MainFrame.Size = UDim2.new(0, MainFrame.AbsoluteSize.X, 0, 310)
        MinBtn.Text = "-"
    end
end)

-- Close
CloseBtn.MouseButton1Click:Connect(function()
    _G.clicking = false
    _G.hatching = false
    ScreenGui:Destroy()
end)
