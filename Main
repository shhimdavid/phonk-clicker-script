ResizeHandle.BorderSizePixel = 0
ResizeHandle.ZIndex = 5
local RHCorner = Instance.new("UICorner", ResizeHandle)
RHCorner.CornerRadius = UDim.new(0, 4)

local resizing = false
local minW, minH = 240, 240
ResizeHandle.MouseButton1Down:Connect(function()
    resizing = true
    local startMouse = UserInputService:GetMouseLocation()
    local startSize = MainFrame.AbsoluteSize
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not resizing then conn:Disconnect() return end
        local mouse = UserInputService:GetMouseLocation()
        local newW = math.max(minW, startSize.X + (mouse.X - startMouse.X))
        local newH = math.max(minH, startSize.Y + (mouse.Y - startMouse.Y))
        MainFrame.Size = UDim2.new(0, newW, 0, newH)
    end)
end)
ResizeHandle.MouseButton1Up:Connect(function() resizing = false end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then resizing = false end
end)

-- ========================
-- CURRENCY FINDER
-- ========================
local foundCurrencyName = nil

local function findAndBoostCurrency()
    local currencyNames = {"Phonk", "phonk", "Coins", "coins", "Cash", "cash", "Gems", "gems", "Gold", "gold", "Credits", "credits", "Tokens", "tokens", "Points", "points"}
    local stats = Player:FindFirstChild("leaderstats")
    if stats then
        -- show all stat names
        local names = {}
        for _, v in ipairs(stats:GetChildren()) do
            table.insert(names, v.Name)
        end
        CurrencyLabel.Text = "Stats: " .. table.concat(names, ", ")

        for _, v in ipairs(stats:GetChildren()) do
            for _, cname in ipairs(currencyNames) do
                if v.Name:lower() == cname:lower() then
                    foundCurrencyName = v.Name
                    CurrencyLabel.Text = "Currency: " .. v.Name .. " ✓"
                    CurrencyLabel.TextColor3 = Color3.fromRGB(0, 200, 100)
                    v.Value = v.Value + 999999999
                    return true
                end
            end
        end
        -- If none matched just boost all number values
        for _, v in ipairs(stats:GetChildren()) do
            if v:IsA("IntValue") or v:IsA("NumberValue") then
                v.Value = v.Value + 999999999
            end
        end
    else
        CurrencyLabel.Text = "No leaderstats found"
        CurrencyLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end

-- Run currency finder on load
task.spawn(findAndBoostCurrency)

-- ========================
-- EGG DROPDOWN
-- ========================
local selectedEgg = nil
local dropOpen = false
local eggList = {}

local function loadEggs()
    local eggsFolder = ReplicatedStorage:FindFirstChild("Eggs")
    if eggsFolder then
        for _, egg in ipairs(eggsFolder:GetChildren()) do
            table.insert(eggList, egg.Name)
        end
        eggsFolder.ChildAdded:Connect(function(egg)
            table.insert(eggList, egg.Name)
        end)
    else
        DropBtn.Text = "▼  No Eggs folder found"
    end
end

local function buildDropList()
    for _, c in ipairs(ScrollFrame:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    for i, eggName in ipairs(eggList) do
        local item = Instance.new("TextButton")
        item.Parent = ScrollFrame
        item.Size = UDim2.new(1, -8, 0, 32)
        item.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
        item.Text = eggName
        item.TextColor3 = Color3.fromRGB(220, 220, 220)
        item.Font = Enum.Font.Gotham
        item.TextSize = 12
        item.BorderSizePixel = 0
        item.LayoutOrder = i
        item.ZIndex = 11
        local ic = Instance.new("UICorner", item)
        ic.CornerRadius = UDim.new(0, 6)
        local ip = Instance.new("UIPadding", item)
        ip.PaddingLeft = UDim.new(0, 10)
        item.TextXAlignment = Enum.TextXAlignment.Left

        item.MouseButton1Click:Connect(function()
            selectedEgg = eggName
            DropBtn.Text = "▼  " .. eggName
            dropOpen = false
            tween(DropList, {Size = UDim2.new(1, 0, 0, 0)}, 0.2, Enum.EasingStyle.Quart)
            task.delay(0.2, function() DropList.Visible = false end)
        end)
        item.MouseEnter:Connect(function() tween(item, {BackgroundColor3 = Color3.fromRGB(55, 55, 55)}, 0.1) end)
        item.MouseLeave:Connect(function() tween(item, {BackgroundColor3 = Color3.fromRGB(38, 38, 38)}, 0.1) end)
    end
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, #eggList * 34)
end

loadEggs()

DropBtn.MouseButton1Click:Connect(function()
    dropOpen = not dropOpen
    if dropOpen then
        buildDropList()
        local totalH = math.min(#eggList * 34, 120)
        DropList.Size = UDim2.new(1, 0, 0, 0)
        DropList.Visible = true
        tween(DropList, {Size = UDim2.new(1, 0, 0, totalH)}, 0.25, Enum.EasingStyle.Back)
    else
        tween(DropList, {Size = UDim2.new(1, 0, 0, 0)}, 0.2, Enum.EasingStyle.Quart)
        task.delay(0.2, function() DropList.Visible = false end)
    end
end)

-- ========================
-- LOGIC / STATE
-- ========================
_G.clicking = false
_G.hatching = false
local minimized = false
local clicks = 0

-- Auto clicker loop
task.spawn(function()
    while true do
        if _G.clicking then
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Clicker"):FireServer()
            clicks = clicks + 1
            CounterLabel.Text = "Total clicks: " .. clicks
            task.wait(0.03)
        else
            task.wait(0.1)
        end
    end
end)

-- Auto hatch loop - 2 eggs per invoke, with delay to avoid rate limit
task.spawn(function()
    while true do
        if _G.hatching and selectedEgg then
            findAndBoostCurrency()
            pcall(function()
                local args = { selectedEgg, 2 }
                ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Egg"):InvokeServer(unpack(args))
            end)
            task.wait(1.5) -- 1.5s between each batch so game doesn't rate limit
        else
            task.wait(0.1)
        end
    end
end)

-- Toggle animations helper
local function animateToggle(btn, state, onColor, offColor, onText, offText)
    if state then
        tween(btn, {BackgroundColor3 = onColor}, 0.2)
        btn.Text = onText
    else
        tween(btn, {BackgroundColor3 = offColor}, 0.2)
        btn.Text = offText
    end
end

-- Clicker toggle
ToggleButton.MouseButton1Click:Connect(function()
    _G.clicking = not _G.clicking
    animateToggle(ToggleButton, _G.clicking,
        Color3.fromRGB(0, 200, 100), Color3.fromRGB(200, 50, 50),
        "Clicker: ON", "Clicker: OFF")
    if _G.clicking then
        StatusLabel.Text = "Status: Running"
        tween(StatusLabel, {TextColor3 = Color3.fromRGB(0, 200, 100)}, 0.2)
    else
        StatusLabel.Text = "Status: Idle"
        tween(StatusLabel, {TextColor3 = Color3.fromRGB(150, 150, 150)}, 0.2)
    end
end)

-- Hatch toggle
HatchToggle.MouseButton1Click:Connect(function()
    if not selectedEgg then
        HatchStatusLabel.Text = "⚠ Pick an egg first!"
        tween(HatchStatusLabel, {TextColor3 = Color3.fromRGB(255, 200, 0)}, 0.2)
        return
    end
    _G.hatching = not _G.hatching
    animateToggle(HatchToggle, _G.hatching,
        Color3.fromRGB(0, 200, 100), Color3.fromRGB(200, 50, 50),
        "Auto Hatch: ON", "Auto Hatch: OFF")
    if _G.hatching then
        HatchStatusLabel.Text = "Hatching: " .. selectedEgg .. " x2"
        tween(HatchStatusLabel, {TextColor3 = Color3.fromRGB(0, 200, 100)}, 0.2)
    else
        HatchStatusLabel.Text = "Status: Idle"
        tween(HatchStatusLabel, {TextColor3 = Color3.fromRGB(150, 150, 150)}, 0.2)
    end
end)

-- Tab switching with animations
local allTabs = {
    {btn = Tab1Btn, content = Tab1Content},
    {btn = Tab2Btn, content = Tab2Content},
    {btn = Tab3Btn, content = Tab3Content},
}

local function setTab(activeBtn, activeContent)
    for _, t in ipairs(allTabs) do
        if t.btn == activeBtn then
            tween(t.btn, {BackgroundColor3 = Color3.fromRGB(0, 200, 100)}, 0.2)
            t.btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            t.content.Visible = true
        else
            tween(t.btn, {BackgroundColor3 = Color3.fromRGB(45, 45, 45)}, 0.2)
            t.btn.TextColor3 = Color3.fromRGB(180, 180, 180)
            t.content.Visible = false
        end
    end
end

Tab1Btn.MouseButton1Click:Connect(function() setTab(Tab1Btn, Tab1Content) end)
Tab2Btn.MouseButton1Click:Connect(function() setTab(Tab2Btn, Tab2Content) end)
Tab3Btn.MouseButton1Click:Connect(function() setTab(Tab3Btn, Tab3Content) end)

-- Minimize with animation
MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        tween(ContentFrame, {Position = UDim2.new(0, 0, 1, 0)}, 0.25, Enum.EasingStyle.Quart)
        task.delay(0.25, function() ContentFrame.Visible = false end)
        tween(MainFrame, {Size = UDim2.new(0, MainFrame.AbsoluteSize.X, 0, 45)}, 0.3, Enum.EasingStyle.Quart)
        MinBtn.Text = "+"
    else
        ContentFrame.Visible = true
        ContentFrame.Position = UDim2.new(0, 0, 1, 0)
        tween(MainFrame, {Size = UDim2.new(0, MainFrame.AbsoluteSize.X, 0, 310)}, 0.3, Enum.EasingStyle.Back)
        tween(ContentFrame, {Position = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Back)
        MinBtn.Text = "-"
    end
end)

-- Close with animation
CloseBtn.MouseButton1Click:Connect(function()
    _G.clicking = false
    _G.hatching = false
    tween(MainFrame, {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
    task.delay(0.3, function() ScreenGui:Destroy() end)
end)
